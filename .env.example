# ── Credenciales Supabase ──────────────────────────────────────────────────────
# Obtén estos valores en: Supabase Dashboard → Settings → API
PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_...

# ── GitHub Pages ───────────────────────────────────────────────────────────────
# Ya no se usa BASE_PATH (ahora se detecta automáticamente desde NODE_ENV).
# El base es '' en desarrollo y '/examen-educacion' en producción.
# Si tu repo tiene otro nombre, edita svelte.config.js → paths.base

# ── Script de calificación con IA (scripts/calificar.js) ──────────────────────
# Ejecutar con: DEEPSEEK_API_KEY=sk-... SUPABASE_URL=... SUPABASE_SERVICE_ROLE_KEY=... node scripts/calificar.js
# DEEPSEEK_API_KEY=            → Obtener en platform.deepseek.com
# SUPABASE_URL=                → URL de tu proyecto Supabase
# SUPABASE_SERVICE_ROLE_KEY=   → service_role key (Settings → API → service_role)
